vars: {
  d2-config: {
    layout-engine: dagre
    pad: 40
  }
}

direction: right

classes: {
  stage: {
    style: {
      fill: "#ffffff"
      stroke: "#1f55ff"
      stroke-width: 2
      border-radius: 10
      font-color: "#172033"
      font-size: 18
      bold: true
    }
  }
  persona: {
    style: {
      fill: "#f7f5ef"
      stroke: "#172033"
      stroke-width: 1
      border-radius: 8
      font-color: "#172033"
      font-size: 14
    }
  }
}

telemetry: "Telemetry\n125 Hz · 73 fields" { class: stage }
windowing: "Windowing\n2 s window" { class: stage }
normalize: "UCS normalization\ndimensionless" { class: stage }
labels: "Physics labels\nBasquin · Arrhenius · Cycle" { class: stage }
model: "LightGBM\nwear-rate model" { class: stage }
cost: "Cost engine\n€ per pick" { class: stage }

views: "Output views" {
  style: {
    fill: "#f7f5ef"
    stroke: "#1f55ff"
    stroke-dash: 4
    border-radius: 12
  }
  cfo: "CFO\nlive billing" { class: persona }
  ops: "Operator\nfleet cost" { class: persona }
  bank: "Bank\ncredit score" { class: persona }
}

telemetry -> windowing
windowing -> normalize
normalize -> labels: "train set"
normalize -> model: "inference"
labels -> model: "train"
model -> cost: "wear_rate_multiplier\n0.3× – 5.0×"
cost -> views.cfo
cost -> views.ops
cost -> views.bank

(* -> *)[*].style: {
  stroke: "#172033"
  stroke-width: 2
  font-color: "#172033"
  font-size: 12
}
