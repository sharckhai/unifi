vars: {
  d2-config: {
    layout-engine: dagre
    pad: 40
    theme-overrides: {
      B1: "#1f55ff"
      B2: "#1f55ff"
      B3: "#172033"
      B4: "#f7f5ef"
      B5: "#ffffff"
      B6: "#ffffff"
      AA2: "#172033"
      AA4: "#687385"
      AA5: "#f7f5ef"
      AB4: "#f7f5ef"
      AB5: "#ffffff"
    }
  }
}

direction: right

classes: {
  stage: {
    style: {
      fill: "#ffffff"
      stroke: "#1f55ff"
      stroke-width: 2
      border-radius: 10
      font-color: "#172033"
      font-size: 18
      bold: true
    }
  }
  persona: {
    style: {
      fill: "#f7f5ef"
      stroke: "#172033"
      stroke-width: 1
      border-radius: 8
      font-color: "#172033"
      font-size: 14
    }
  }
}

telemetry: "Telemetrie\n125 Hz · 73 Felder" { class: stage }
windowing: "Windowing\n2 s Fenster" { class: stage }
normalize: "UCS-Normalisierung\ndimensionslos" { class: stage }
labels: "Physik-Labels\nBasquin · Arrhenius · Cycle" { class: stage }
model: "LightGBM\nWear-Rate-Modell" { class: stage }
cost: "Cost-Engine\n€ pro Pick" { class: stage }

views: "Output-Views" {
  style: {
    fill: "#f7f5ef"
    stroke: "#1f55ff"
    stroke-dash: 4
    border-radius: 12
  }
  cfo: "CFO\nLive-Billing" { class: persona }
  ops: "Operator\nFlotten-Cost" { class: persona }
  bank: "Bank\nCredit Score" { class: persona }
}

telemetry -> windowing
windowing -> normalize
normalize -> labels: "Train-Set"
normalize -> model: "Inference"
labels -> model: "Train"
model -> cost: "wear_rate_multiplier\n0.3× – 5.0×"
cost -> views.cfo
cost -> views.ops
cost -> views.bank

(* -> *)[*].style: {
  stroke: "#172033"
  stroke-width: 2
  font-color: "#172033"
  font-size: 12
}
