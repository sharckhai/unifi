vars: {
  d2-config: {
    layout-engine: dagre
    pad: 40
  }
}

shape: sequence_diagram

user: "User\n(new robot owner)" {
  style.font-color: "#172033"
  style.bold: true
}

ucs_agent: "UCS agent\n(LLM function calls)" {
  style.font-color: "#1f55ff"
  style.bold: true
}

normalizer: "UCS normalizer" {
  style.font-color: "#172033"
}

model: "Wear-rate model\n(pretrained on UR5)" {
  style.font-color: "#1f55ff"
}

cost_engine: "Cost engine" {
  style.font-color: "#172033"
}

drop: {
  user -> ucs_agent: "drop( telemetry CSV + datasheet )"
}

map_telemetry: "Schema mapping" {
  ucs_agent -> ucs_agent: "LLM call 1\nfield names → UCS schema"
  ucs_agent -> ucs_agent: "LLM call 2\ndatasheet → constants"
  ucs_agent -> user: "mapping proposal\nwith confidence"
  user -> ucs_agent: "confirm"
}

inference: "Inference — no re-training" {
  ucs_agent -> normalizer: "raw telemetry + datasheet"
  normalizer -> model: "dimensionless UCS features"
  model -> cost_engine: "wear_rate_multiplier"
  cost_engine -> user: "cost-per-pick — live"
}
